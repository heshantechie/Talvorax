# Environment Variables for HireReady AI
# Copy this to .env and fill in your values

# Railway PDF Backend
VITE_API_URL=https://talvorax.up.railway.app

# Supabase (Development)
VITE_SUPABASE_URL=your_dev_supabase_url
VITE_SUPABASE_ANON_KEY=your_dev_anon_key

# Sentry (optional — leave empty to disable)
VITE_SENTRY_DSN=

# ─── Server Security Settings (server/.env) ──────────────────────────────────

# CORS — Comma-separated list of allowed origins in production.
# Leave unset to use the hardcoded production fallback list.
# CORS_ALLOWED_ORIGINS=https://yourapp.vercel.app,https://yourapp.railway.app

# Puppeteer — Set to 'true' ONLY on containerized hosts that lack user-namespace support.
# Never set to 'true' in development or non-containerized production.
# PUPPETEER_DISABLE_SANDBOX=true

# Set to 'true' AND NODE_ENV != 'production' to save debug screenshots to tmp.
# PDF_DEBUG_SCREENSHOT=true
